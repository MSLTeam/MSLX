<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MSLX.Desktop.ViewModels.CreateTunnel.MSLFrp"
             xmlns:models="using:MSLX.Desktop.Models"
             xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MSLX.Desktop.Views.CreateTunnel.MSLFrp.MainPage"
             x:DataType="vm:MainPageViewModel">
    <UserControl.DataContext>
        <vm:MainPageViewModel/>
    </UserControl.DataContext>
  <Grid>
    <TabControl x:Name="MainTabControl">
      <!-- 隧道列表 -->
      <TabItem Header="我的隧道">
        <Grid Margin="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- 左：隧道列表 -->
          <suki:GlassCard Margin="0,0,10,0">
            <Grid RowDefinitions="Auto * Auto">
              <TextBlock Text="隧道列表：" FontWeight="Bold" FontSize="16"/>
              <ListBox x:Name="TunnelListBox" Margin="0,5,0,0" Grid.Row="1"
                       SelectedItem="{Binding SelectedTunnel}"
                       ItemsSource="{Binding Tunnels}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Remarks}" Foreground="Gray"/>
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
              </ListBox>
              <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="刷新" Classes="Flat" Click="RefreshTunnels_Click"/>
                <Button Grid.Column="1" Margin="5,0,5,0" Content="删除隧道"
                        Classes="Flat Accent" Background="Red" Click="DeleteTunnel_Click"/>
              </Grid>
            </Grid>
          </suki:GlassCard>

          <!-- 右：用户/隧道信息 -->
          <Grid Grid.Column="1">
            <ScrollViewer>
              <StackPanel Spacing="10">

                <!-- 用户信息卡片 -->
                <suki:GlassCard>
                  <Grid>
                    <StackPanel>
                      <TextBlock Text="用户信息" Margin="3" FontWeight="Bold" FontSize="16"/>
                      <TextBlock Margin="3">
                        <Run Text="用户名："/>
                        <Run x:Name="UsernameText"/>
                      </TextBlock>
                      <TextBlock Margin="3">
                        <Run Text="用户组："/>
                        <Run x:Name="UserGroupText"/>
                      </TextBlock>
                      <TextBlock Margin="3">
                        <Run Text="最大隧道数："/>
                        <Run x:Name="UserMaxTunnelsText"/>
                      </TextBlock>
                      <TextBlock Margin="3">
                        <Run Text="到期时间："/>
                        <Run x:Name="UserOutdatedText"/>
                      </TextBlock>
                    </StackPanel>
                    <Grid VerticalAlignment="Top" HorizontalAlignment="Right">
                      <StackPanel Spacing="5">
                        <Button Classes="Flat" Content="打开官网" Click="OpenWebsite_Click"/>
                        <Button Classes="Flat Accent" Background="Red" Content="退出登录" Click="ExitLogin_Click"/>
                      </StackPanel>
                    </Grid>
                  </Grid>
                </suki:GlassCard>

                <!-- 隧道信息卡片 -->
                <suki:GlassCard>
                  <StackPanel Spacing="10">
                    <TextBlock Text="隧道信息" FontWeight="Bold" FontSize="16"/>
                    <TextBlock>
                      <Run Text="名称："/>
                      <Run Text="{Binding SelectedTunnel.Name}"/>
                    </TextBlock>
                    <TextBlock>
                      <Run Text="备注："/>
                      <Run Text="{Binding SelectedTunnel.Remarks}"/>
                    </TextBlock>
                    <TextBlock>
                      <Run Text="状态："/>
                      <Run Text="{Binding SelectedTunnel.Status}"/>
                    </TextBlock>
                    <TextBlock>
                      <Run Text="本地端口："/>
                      <Run Text="{Binding SelectedTunnel.LocalPort}"/>
                    </TextBlock>
                    <TextBlock>
                      <Run Text="远程端口："/>
                      <Run Text="{Binding SelectedTunnel.RemotePort}"/>
                    </TextBlock>
                    <TextBlock>
                      <Run Text="节点："/>
                      <Run Text="{Binding SelectedTunnel.Node}"/>
                    </TextBlock>
                    <Button Content="使用该隧道" Height="50" Classes="Flat"
                            FontSize="18" Click="UseTunnel_Click"/>
                  </StackPanel>
                </suki:GlassCard>

              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>
      </TabItem>

      <!-- 创建隧道 -->
      <TabItem Header="创建隧道">
        <Grid Grid.ColumnDefinitions="* *" Margin="10">

          <!-- 左：节点列表 -->
          <Grid Margin="0,0,10,0">
            <suki:GlassCard>
              <Grid RowDefinitions="Auto * Auto">
                <TextBlock Text="节点列表：" FontSize="16" FontWeight="Bold"/>
                <ListBox x:Name="NodeListBox" Margin="0,5,0,0" Grid.Row="1"
                         SelectedItem="{Binding SelectedNode}"
                         ItemsSource="{Binding Nodes}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                          <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                          <TextBlock Text="{Binding Remarks}" Foreground="Gray"/>
                        </StackPanel>
                      </DataTemplate>
                        </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Row="2" Content="刷新" Classes="Flat" Click="RefreshNodes_Click"/>
              </Grid>
            </suki:GlassCard>
          </Grid>

          <!-- 右：节点信息 + 创建隧道表单 -->
          <Grid Grid.Column="1">
            <ScrollViewer>
              <StackPanel Spacing="10">

                <!-- 节点信息卡片 -->
                <suki:GlassCard>
                  <StackPanel Spacing="10">
                    <TextBlock Text="节点信息：" FontSize="16" FontWeight="Bold"/>
                    <TextBlock>
                      <Run Text="节点名称："/>
                      <Run Text="{Binding SelectedNode.Name}"/>
                    </TextBlock>
                    <TextBlock>
                      <Run Text="信息："/>
                      <Run Text="{Binding SelectedNode.Remarks}"/>
                    </TextBlock>
                  </StackPanel>
                </suki:GlassCard>

                <!-- 创建隧道表单卡片 -->
                <suki:GlassCard>
                  <StackPanel Spacing="10">
                    <TextBlock Text="填写隧道信息：" FontSize="16" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock VerticalAlignment="Center" Text="隧道名称："/>
                      <TextBox x:Name="CreateNameBox" MinWidth="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock VerticalAlignment="Center" Text="协议类型："/>
                      <ComboBox x:Name="CreateTypeCombo" MinWidth="150" SelectedIndex="0">
                        <ComboBoxItem>tcp</ComboBoxItem>
                        <ComboBoxItem IsEnabled="{Binding SelectedNode.UdpSupport}">udp</ComboBoxItem>
                        <ComboBoxItem IsEnabled="{Binding SelectedNode.HttpSupport}">http</ComboBoxItem>
                        <ComboBoxItem IsEnabled="{Binding SelectedNode.HttpSupport}">https</ComboBoxItem>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock VerticalAlignment="Center" Text="本地IP："/>
                      <TextBox x:Name="CreateLocalIpBox" MinWidth="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock VerticalAlignment="Center" Text="本地端口："/>
                      <NumericUpDown x:Name="CreateLocalPortBox" MinWidth="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock VerticalAlignment="Center" Text="远程端口："/>
                      <NumericUpDown x:Name="CreateRemotePortBox" MinWidth="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock VerticalAlignment="Center" Text="使用KCP协议传输："/>
                      <ToggleSwitch x:Name="CreateKcpToggle"/>
                    </StackPanel>
                    <Button Content="创建隧道" Height="50" Classes="Flat"
                            FontSize="18" Click="CreateTunnel_Click"/>
                  </StackPanel>
                </suki:GlassCard>

              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>